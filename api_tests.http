//-------crate item ------
###
# ==========================================
# ITEAM PROFILE MODULE: CREATE ITEMS (PRODUCTS)
# ==========================================

### Create a new item
POST http://localhost:8080/api/v1/profile-items/items
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "category_id": 1,
    "sub_category_id": 1,
    "minor_category_id": 1,
    "item_type_id": 1,
    "calculate_base_price_id": 1,
    "sales_tax_setup_id": 1,
    "sales_supply_type_id": 1,
    "supplier_id": 1,
    "department_id": 1,
    "name": "Samsung Galaxy S21",
    "barcode": "8806092489475",
    "description": "High-end smartphone with excellent camera and display",
    "sku": "SAMS-GAL-S21-001",
    "cost_price": 45000,
    "standard_sales_price": 65000,
    "cost_on_gp": 48000,
    "last_cost": 44500,
    "avg_cost": 45500,
    "alt_umo": 1,
    "alt_unit": "piece",
    "max_discount": 15,
    "reorder_minimum_qty": 5,
    "item_image": "https://example.com/images/samsung-s21.jpg",
    "notes": "Latest model, high demand item",
    "is_child_barcode": false,
    "auto_barcode": false,
    "can_be_sold": true,
    "can_be_produced": false,
    "can_be_rented": false,
    "can_be_purchased": true,
    "is_vat_rebatable": false,
    "is_not_allow_decimal": true,
    "is_active": true
}

### Get all items
GET http://localhost:8080/api/v1/profile-items/items
Authorization: Bearer {{token}}

### Get item by ID
GET http://localhost:8080/api/v1/profile-items/items/1
Authorization: Bearer {{token}}

### Update item
PUT http://localhost:8080/api/v1/profile-items/items/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "name": "Samsung Galaxy S21 Pro",
    "standard_sales_price": 75000,
    "cost_price": 50000,
    "max_discount": 20,
    "is_active": true
}

### Partial update item (only price fields)
PUT http://localhost:8080/api/v1/profile-items/items/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "standard_sales_price": 72000,
    "cost_price": 48000,
    "max_discount": 18
}

### Delete item
DELETE http://localhost:8080/api/v1/profile-items/items/1
Authorization: Bearer {{token}}
